# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Frontend -> backend proxy target for Vite dev server.
VITE_API_TARGET="http://127.0.0.1:8787"

# Bind to loopback by default. For access from a trusted LAN, set both hosts to
# 0.0.0.0 and configure ALLOWED_ORIGINS with the exact frontend URL(s).
API_HOST="127.0.0.1"
FRONTEND_HOST="127.0.0.1"
# start.sh uses dev mode by default. Set preview to build before serving dist/.
FRONTEND_MODE="dev"

# Backend runtime options (used by backend/server.mjs).
API_PORT="8787"
PIPELINE_PYTHON=""
PIPELINE_ROOT=""
PIPELINE_WORK_DIR=""

# Optional convenience protection for local/trusted single-user deployments.
# When set, all /api/ requests must include: x-api-key: <key>
API_KEY=""

# If API_KEY is enabled for the browser UI, VITE_API_KEY must have the same
# value. VITE_* values are embedded in the browser bundle and are NOT secrets;
# this mechanism is not a substitute for multi-user authentication.
VITE_API_KEY=""

# Comma-separated browser origins. If empty, the backend only allows the local
# defaults http://127.0.0.1:3000 and http://localhost:3000.
# Trusted-LAN example: http://192.168.1.20:3000
ALLOWED_ORIGINS=""

# External property-prediction services. EC, CataPro, and PLM_Sol are called
# through their /predict/batch endpoints; Tm currently uses /predict per item.
CATAPRO_URL="http://127.0.0.1:8003"
SOL_URL="http://127.0.0.1:8004"
EC_URL="http://127.0.0.1:8000"
TM_URL="http://127.0.0.1:8005"

# Number of candidates sent in each EC/CataPro/PLM_Sol HTTP batch. The backend
# clamps this to 1..256. Smaller batches update progress and ETA more often.
PREDICTION_BATCH_SIZE="64"
# Timeout for each external prediction request (milliseconds; default 10 min).
PREDICTION_REQUEST_TIMEOUT_MS="600000"
